TELEGRAM_BOT_TOKEN=123456:ABCDEF_YOUR_BOT_TOKEN

# Comma-separated Telegram user IDs allowed to use /subscribers and /notify.
# Get your id via @userinfobot or similar.
ADMIN_TELEGRAM_IDS=

# Optional shared defaults for both endpoints:
# PANEL_URL=https://your-panel:7334/
# PANEL_USERNAME=admin
# PANEL_PASSWORD=your_password
# PANEL_API_TOKEN=   # preferred: Settings → Security → API Token (skips CSRF login)
# PANEL_TLS_INSECURE=true  # only if panel uses a self-signed cert

# --- Endpoint 1 ---
ENDPOINT_1_NAME=Server 1
ENDPOINT_1_PANEL_URL=https://159.223.65.15:7334/
ENDPOINT_1_PANEL_USERNAME=zembi
ENDPOINT_1_PANEL_PASSWORD=your_password
# ENDPOINT_1_API_TOKEN=
ENDPOINT_1_TLS_INSECURE=true
ENDPOINT_1_PUBLIC_HOST=159.223.65.15
# ENDPOINT_1_PUBLIC_PORT=443

# --- Endpoint 2 ---
ENDPOINT_2_NAME=Server 2
ENDPOINT_2_PANEL_URL=https://168.144.138.250:7334/
ENDPOINT_2_PANEL_USERNAME=zembi
ENDPOINT_2_PANEL_PASSWORD=your_password
# ENDPOINT_2_API_TOKEN=
ENDPOINT_2_TLS_INSECURE=true
ENDPOINT_2_PUBLIC_HOST=168.144.138.250
# ENDPOINT_2_PUBLIC_PORT=443

# Refresh 3x-ui cached clients/inbounds every N milliseconds.
XUI_REFRESH_MS=300000
