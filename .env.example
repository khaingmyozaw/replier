TELEGRAM_BOT_TOKEN=123456:ABCDEF_YOUR_BOT_TOKEN

# 3x-ui panel base URL (root URL WITHOUT /panel suffix)
PANEL_URL=http://143.198.82.227:7334/
PANEL_USERNAME=admin
PANEL_PASSWORD=your_admin_password

# Where Telegram users should connect
# If not set, username->uuid lookup still requires these fields to render links correctly.
VLESS_PUBLIC_HOST=143.198.82.227
# Optional. If unset, username->uuid lookup will use the inbound's configured port.
# If set, it will also override port for pasted `vless://...` links.
# VLESS_PUBLIC_PORT=443

# Refresh 3x-ui cached clients/inbounds every N milliseconds.
XUI_REFRESH_MS=300000

